{
  "manifest_version": 3,
  "name": "Scripts Injector",
  "version": "1.0.1",
  "description": "Inject custom CSS and JS into any website based on URL patterns.",
  "author": "krittanon-w",
  "homepage_url": "https://github.com/krittanon-w/kw-browser-extension-scripts-injector",
  "permissions": [
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "options_page": "src/options/index.html"
}
